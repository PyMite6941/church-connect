{
  "name": "church-connect",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Embeddable, multi-tenant church engagement tool. Drop it on any church's subdomain; accounts and data are configurable per tenant.",
  "scripts": {
